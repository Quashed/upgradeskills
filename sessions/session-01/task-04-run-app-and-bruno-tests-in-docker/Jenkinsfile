pipeline {
    agent any

    tools {
        nodejs 'node20'
    }

    stages {
        stage('Checkout') {
            steps {
                git(
                    branch: 'main',
                    credentialsId: 'github-upgradeskills-https',
                    url: 'https://github.com/Quashed/hello-demo.git'
                )
            }
        }

        stage('Build') {
            steps {
                sh 'chmod +x mvnw && ./mvnw clean test'
            }
        }

        stage('Start App') {
            steps {
                sh './mvnw spring-boot:run &'
            }
        }

        stage('Run Bruno') {
            steps {
                dir('bruno') {
                    sh 'npx @usebruno/cli run .'
                }
            }
        }
    }
}